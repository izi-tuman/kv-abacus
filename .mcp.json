{
	"mcpServers": {
		"context7": {
			"command": "cmd",
			"args": ["/c", "npx", "-y", "@upstash/context7-mcp"]
		},
		"next-devtools": {
			"command": "npx",
			"args": ["-y", "next-devtools-mcp@latest"]
		},
		"magicuidesign-mcp": {
			"command": "npx",
			"args": ["-y", "@magicuidesign/mcp@latest"]
		},
		"playwright": {
			"command": "cmd",
			"args": ["/c", "npx", "-y", "@playwright/mcp@latest"]
		}
	}
}
